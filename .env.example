# Postgres (Neon) — copy your branch's connection string from console.neon.tech
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Tell Clerk to render its sign-in/up UI on local routes (catch-all pages
# under app/sign-in and app/sign-up) instead of redirecting to its hosted
# Account Portal. Without these, /sign-in and /sign-up will 404.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/learn
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/learn

# OpenRouter — powers the Jeremiah AI floating chat assistant
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxx

# Cloudflare R2 — hosts course videos (public reads via custom domain)
# AND student tape uploads (signed PUT URLs from /api/submissions/upload).
# Generate access keys at: Cloudflare → R2 → Manage R2 API Tokens.
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=guitar
R2_PUBLIC_BASE=https://videos.thanielguitarlessons.com

# Resend — sends "new tape submitted" emails to the admin and review
# notifications back to students. Get a key at https://resend.com/api-keys
# (free tier covers 100 emails/day; uses onboarding@resend.dev as the
# from-address, no domain verification needed for sending to yourself).
RESEND_API_KEY=re_xxx

# Email address gating /admin/* access. Must match a Clerk-registered email.
ADMIN_EMAIL=jeremiahomolewa.work@gmail.com

# Where the inbound contact-form / submission notifications get delivered.
# Defaults to ADMIN_EMAIL. Override when Resend can't yet deliver to your
# admin email (e.g. on free tier before domain verification — must be the
# email used to create the Resend account).
# CONTACT_EMAIL=jeremiah.omolewa@deepshi.ai

# Optional: override the from-address Resend sends with. Defaults to
# Resend's onboarding@resend.dev which only delivers to the Resend
# account owner's email. Once you verify a domain on Resend (5 min),
# set this to e.g. "Jerry <hi@thanielguitarlessons.com>" to send to anyone.
# RESEND_FROM_EMAIL=Jerry <hi@thanielguitarlessons.com>

# Next.js
NEXT_PUBLIC_BASE_URL=http://localhost:3000
